# Local development with Supabase CLI defaults
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_local_anon_key_from_supabase_start
SUPABASE_SERVICE_ROLE_KEY=replace_with_local_service_role_key_from_supabase_start

# AI provider. Leave AI_API_KEY empty to use the mock local fallback.
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=

# Production-only messaging / cron
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
CRON_SECRET=
